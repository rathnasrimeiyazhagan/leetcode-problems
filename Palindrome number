class Solution {
    public boolean isPalindrome(int x) {
        int ld=0;
        int temp=x;
        int rev=0;
        if(x<0){
            return false;
        }
        while(x!=0){
            ld=x%10;
            rev=rev*10+ld;
            x/=10;
        }
        if(temp==rev){
            return true;
        }
        else{
            return false;
        }

    }
}
